# Backend
NEXT_PUBLIC_API_URL=http://localhost:8000

# Supabase (Project Settings → API in the Supabase dashboard)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Sentry
NEXT_PUBLIC_SENTRY_DSN=

# «Войти как тестовый пользователь» button on /sign-in — local dev only.
# Leave both empty in production: the button (and its credentials) is then
# never rendered and never reaches the client bundle.
NEXT_PUBLIC_TEST_LOGIN_EMAIL=
NEXT_PUBLIC_TEST_LOGIN_PASSWORD=
