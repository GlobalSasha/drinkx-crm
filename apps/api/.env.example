APP_ENV=development
LOG_LEVEL=INFO
CORS_ORIGINS=["http://localhost:3000"]

# Database (matches docker-compose default)
DATABASE_URL=postgresql+asyncpg://drinkx:drinkx@localhost:5432/drinkx_crm

# Redis
REDIS_URL=redis://localhost:6379/0

# Supabase Auth (Project Settings → API in the Supabase dashboard)
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
SUPABASE_JWT_SECRET=

# AI providers (ADR-018)
# Primary: MiMo (Xiaomi, OpenAI-compatible). Fallback chain: MiMo → Groq → Anthropic → Gemini → DeepSeek
MIMO_API_KEY=
MIMO_BASE_URL=https://api.xiaomimimo.com/v1
MIMO_MODEL_PRO=mimo-v2-pro
MIMO_MODEL_FLASH=mimo-v2-flash
# Groq — free tier, OpenAI-compatible, reliable from RU IPs.
# Sign up at https://console.groq.com to get an API key.
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-70b-instruct
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5
GEMINI_API_KEY=
DEEPSEEK_API_KEY=
OPENAI_API_KEY=
BRAVE_API_KEY=
APIFY_TOKEN=
CRM_AI_BACKEND=mimo
LLM_FALLBACK_CHAIN=["mimo","groq","anthropic","gemini","deepseek"]

# Sentry
SENTRY_DSN=

# Cost guards
AI_MONTHLY_BUDGET_USD=200
AI_MAX_PARALLEL_JOBS=5
AI_MAX_ENRICHMENTS_PER_LEAD_PER_DAY=1
