APP_ENV=development
LOG_LEVEL=INFO
CORS_ORIGINS=["http://localhost:3000"]

# Database (matches docker-compose default)
DATABASE_URL=postgresql+asyncpg://drinkx:drinkx@localhost:5432/drinkx_crm

# Redis
REDIS_URL=redis://localhost:6379/0

# Supabase Auth (Project Settings → API in the Supabase dashboard)
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
SUPABASE_JWT_SECRET=

# AI providers
DEEPSEEK_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
BRAVE_API_KEY=
APIFY_TOKEN=
CRM_AI_BACKEND=deepseek

# Sentry
SENTRY_DSN=

# Cost guards
AI_MONTHLY_BUDGET_USD=200
AI_MAX_PARALLEL_JOBS=5
AI_MAX_ENRICHMENTS_PER_LEAD_PER_DAY=1
