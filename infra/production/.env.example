# Copy to .env on the server, fill in real values, NEVER commit .env

# Postgres (host-only — only the API container connects to it)
POSTGRES_USER=drinkx
POSTGRES_PASSWORD=CHANGE_ME_LONG_RANDOM
POSTGRES_DB=drinkx_crm

# Supabase (from https://app.supabase.com → Project Settings → API)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=
SUPABASE_JWT_SECRET=

# AI providers
DEEPSEEK_API_KEY=
OPENAI_API_KEY=
BRAVE_API_KEY=
APIFY_TOKEN=

# Sentry — separate DSN per project
SENTRY_DSN_API=
SENTRY_DSN_WEB=

# Cost guard
AI_MONTHLY_BUDGET_USD=200
