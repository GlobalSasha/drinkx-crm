# Copy to .env on the server, fill in real values, NEVER commit .env

# Postgres (host-only — only the API container connects to it)
POSTGRES_USER=drinkx
POSTGRES_PASSWORD=CHANGE_ME_LONG_RANDOM
POSTGRES_DB=drinkx_crm

# Supabase (from https://app.supabase.com → Project Settings → API)
# Naming follows the modern Supabase dashboard:
#   PUBLISHABLE_KEY = old "anon key" (safe in browser)
#   SECRET_KEY      = old "service_role key" (server only)
#   JWT_SECRET      = Project Settings → API → JWT Settings → JWT Secret
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
SUPABASE_JWT_SECRET=

# AI providers (ADR-018: MiMo primary; fallback chain MiMo → Anthropic → Gemini → DeepSeek)
MIMO_API_KEY=
MIMO_BASE_URL=https://api.xiaomimimo.com/v1
MIMO_MODEL_PRO=mimo-v2-pro
MIMO_MODEL_FLASH=mimo-v2-flash
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5
GEMINI_API_KEY=
DEEPSEEK_API_KEY=
OPENAI_API_KEY=
BRAVE_API_KEY=
APIFY_TOKEN=
CRM_AI_BACKEND=mimo
LLM_FALLBACK_CHAIN=["mimo","anthropic","gemini","deepseek"]

# Sentry — separate DSN per project
SENTRY_DSN_API=
SENTRY_DSN_WEB=

# Cost guard
AI_MONTHLY_BUDGET_USD=200

# SMTP — Daily email digest (Sprint 1.5).
# Leave SMTP_HOST empty to run in stub mode (digest content is logged to
# stdout instead of sent — useful for staging / first-run verification).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=DrinkX CRM <noreply@crm.drinkx.tech>
